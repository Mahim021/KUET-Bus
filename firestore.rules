rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isKuetStudentEmail() {
      return signedIn()
        && request.auth.token.email is string
        && request.auth.token.email.matches('^[A-Za-z]+[0-9]{7}@stud\\.kuet\\.ac\\.bd$');
    }

    function isAdmin() {
      return signedIn() && request.auth.token.role == 'admin';
    }

    function canUseApp() {
      return isKuetStudentEmail() || isAdmin();
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function hasNonEmptyString(field) {
      return field is string && field.size() > 0;
    }

    function busUniqueIndexOk(busId) {
      return hasNonEmptyString(request.resource.data.busNumberKey)
        && existsAfter(/databases/$(database)/documents/unique_bus_numbers/$(request.resource.data.busNumberKey))
        && getAfter(/databases/$(database)/documents/unique_bus_numbers/$(request.resource.data.busNumberKey)).data.busId == busId;
    }

    function routeUniqueIndexOk(routeId) {
      return hasNonEmptyString(request.resource.data.routeNameKey)
        && existsAfter(/databases/$(database)/documents/unique_route_names/$(request.resource.data.routeNameKey))
        && getAfter(/databases/$(database)/documents/unique_route_names/$(request.resource.data.routeNameKey)).data.routeId == routeId;
    }

    match /users/{uid} {
      allow read: if canUseApp() && (isOwner(uid) || isAdmin());

      // Each user must use a KUET student email and cannot change identity fields.
      allow create: if canUseApp()
        && isOwner(uid)
        && request.resource.data.uid == uid
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.email.matches('^[A-Za-z]+[0-9]{7}@stud\\.kuet\\.ac\\.bd$')
        && request.resource.data.kuetId is string
        && request.resource.data.kuetId.matches('^[0-9]{7}$')
        && request.resource.data.batch is string
        && request.resource.data.batch.matches('^20[0-9]{2}$')
        && request.resource.data.department is string
        && request.resource.data.department.matches('^[0-9]{2}$')
        && request.resource.data.role == 'student';

      allow update: if isAdmin()
        || (
          canUseApp()
          && isOwner(uid)
          && request.resource.data.uid == resource.data.uid
          && request.resource.data.email == resource.data.email
          && request.resource.data.email == request.auth.token.email
          && request.resource.data.kuetId == resource.data.kuetId
          && request.resource.data.batch == resource.data.batch
          && request.resource.data.department == resource.data.department
          && request.resource.data.role == resource.data.role
          && (
            !('createdAt' in resource.data)
            || request.resource.data.createdAt == resource.data.createdAt
          )
        );
      allow delete: if isAdmin();
    }

    match /notices/{docId} {
      allow read: if canUseApp();
      allow write: if isAdmin();
    }

    match /buses/{docId} {
      allow read: if canUseApp();
      allow create: if isAdmin() && busUniqueIndexOk(docId);
      allow update: if isAdmin() && busUniqueIndexOk(docId);
      allow delete: if isAdmin();
    }

    match /routes/{docId} {
      allow read: if canUseApp();
      allow create: if isAdmin() && routeUniqueIndexOk(docId);
      allow update: if isAdmin() && routeUniqueIndexOk(docId);
      allow delete: if isAdmin();
    }

    match /schedules/{docId} {
      allow read: if canUseApp();
      allow write: if isAdmin();
    }

    match /bus_locations/{docId} {
      allow read: if canUseApp();
      allow write: if isAdmin();
    }

    match /unique_bus_numbers/{key} {
      allow read: if isAdmin();
      allow create: if isAdmin()
        && !exists(/databases/$(database)/documents/unique_bus_numbers/$(key))
        && hasNonEmptyString(request.resource.data.busId)
        && hasNonEmptyString(request.resource.data.busNumber);
      allow delete: if isAdmin();
      allow update: if false;
    }

    match /unique_route_names/{key} {
      allow read: if isAdmin();
      allow create: if isAdmin()
        && !exists(/databases/$(database)/documents/unique_route_names/$(key))
        && hasNonEmptyString(request.resource.data.routeId)
        && hasNonEmptyString(request.resource.data.routeName);
      allow delete: if isAdmin();
      allow update: if false;
    }

    // Deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
