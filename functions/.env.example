# Copy this file to .env and fill in all values before deploying.
# Never commit .env — it is gitignored.

# OpenAI
OPENAI_API_KEY=

# Gmail OAuth2 credentials (from Google Cloud Console)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_USER=your-kuet-inbox@gmail.com

# Google Pub/Sub topic name (just the short name, not the full resource path)
# e.g. gmail-kuet-watch
PUBSUB_TOPIC=gmail-kuet-watch

# Authority email — emails from this address trigger AI extraction
# e.g. transport@kuet.ac.bd
AUTHORITY_EMAIL=transport@kuet.ac.bd
